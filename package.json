{
  "name": "@signvoy/node",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the Signvoy e-signature API",
  "license": "MIT",
  "author": "Signvoy Inc.",
  "homepage": "https://www.signvoy.com/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/signvoy/signvoy-node.git"
  },
  "bugs": {
    "url": "https://github.com/signvoy/signvoy-node/issues"
  },
  "keywords": [
    "signvoy",
    "esignature",
    "e-signature",
    "electronic-signature",
    "digital-signature",
    "pdf",
    "pdf-signing",
    "signing",
    "signing-api",
    "docusign-alternative",
    "sdk",
    "node",
    "nodejs",
    "typescript",
    "webhooks",
    "api"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./webhooks": {
      "import": "./dist/src/webhooks.js",
      "types": "./dist/src/webhooks.d.ts"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "cross-fetch": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
